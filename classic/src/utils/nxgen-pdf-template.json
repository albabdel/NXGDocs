  "programmaticUsage": {
    "docxLibrary": "docx (npm)",
    "notes": [
      "Use docx library to create Word documents programmatically",
      "Logo image should be embedded as base64 or file reference",
      "All sizes in twips: 1 inch = 1440 twips",
      "Font sizes in half-points: 1 point = 2 half-points",
      "EMU (English Metric Units): 1 inch = 914400 EMUs",
      "Border sizes in eighths of a point: 4 = 0.5pt"
    ]
