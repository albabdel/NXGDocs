# Admin Server Configuration (Legacy - can be removed if not needed)
ADMIN_PORT=3001
ADMIN_PASSWORD=admin123

# Editor Configuration
AUTO_SAVE_INTERVAL=30000
MAX_IMAGE_SIZE_MB=5

# Gemini API Configuration (for AI translations)
# Get your API key from: https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# PRODUCTION CONFIGURATION
# ============================================

# Algolia DocSearch Configuration
# Apply at: https://docsearch.algolia.com/apply/
# Once approved, you'll receive these credentials
ALGOLIA_APP_ID=YOUR_APP_ID_HERE
ALGOLIA_API_KEY=YOUR_SEARCH_API_KEY_HERE
ALGOLIA_INDEX_NAME=nxgen_docs

# Strapi CMS Configuration
# From Agent 3 after Strapi setup is complete
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=YOUR_STRAPI_API_TOKEN_HERE

# Deployment Configuration
NODE_ENV=production
BUILD_PATH=build
