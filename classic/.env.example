# Admin Server Configuration (Legacy - can be removed if not needed)
ADMIN_PORT=3001
ADMIN_PASSWORD=admin123

# Editor Configuration
AUTO_SAVE_INTERVAL=30000
MAX_IMAGE_SIZE_MB=5

# Gemini API Configuration (for AI translations)
# Get your API key from: https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# PRODUCTION CONFIGURATION
# ============================================

# Algolia DocSearch Configuration
# Apply at: https://docsearch.algolia.com/apply/
# Once approved, you'll receive these credentials
ALGOLIA_APP_ID=YOUR_APP_ID_HERE
ALGOLIA_API_KEY=YOUR_SEARCH_API_KEY_HERE
ALGOLIA_INDEX_NAME=nxgen_docs

# Strapi CMS Configuration
# From Agent 3 after Strapi setup is complete
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=YOUR_STRAPI_API_TOKEN_HERE

# Deployment Configuration
NODE_ENV=production
BUILD_PATH=build

# ============================================
# STORYBLOK CMS CONFIGURATION (PRIMARY CMS)
# ============================================

# Storyblok Public Access Token (REQUIRED)
# Get from: https://app.storyblok.com → Settings → Access Tokens
# This is used for fetching published content
STORYBLOK_ACCESS_TOKEN=your_public_access_token_here

# Storyblok Management Token (REQUIRED for CLI operations)
# Get from: https://app.storyblok.com → Settings → Access Tokens → Personal Access Tokens
# This is used for management API and CLI operations
STORYBLOK_MANAGEMENT_TOKEN=your_management_token_here

# Storyblok Region (REQUIRED)
# Options: eu, us, ap, ca, cn
STORYBLOK_REGION=eu

# Storyblok Space ID (REQUIRED)
# Your space ID from Storyblok dashboard
STORYBLOK_SPACE_ID=289434723537263

# Preview Mode (REQUIRED)
# Set to "true" for local development (loads draft content)
# Set to "false" for production (loads published content)
STORYBLOK_IS_PREVIEW=true

# ============================================
# EMAIL SERVICE CONFIGURATION
# ============================================

# SMTP Configuration (REQUIRED for feedback widget)
# ZeptoMail or your email service provider credentials
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here

# ============================================
# HYGRAPH CMS CONFIGURATION (OPTIONAL - LEGACY)
# ============================================

# NOTE: We are using Storyblok as primary CMS
# Hygraph configuration is optional and only needed if HYGRAPH_AS_SOURCE=true

# Hygraph Endpoint (public URL - safe to commit)
HYGRAPH_ENDPOINT=https://api-eu-west-2.hygraph.com/v2/cmcd3s4gx00uq07w3xhw9djjz/master

# Hygraph API Token (OPTIONAL - only if using Hygraph)
# HYGRAPH_TOKEN=your_hygraph_token_here

# Hygraph Management Token (OPTIONAL - only if using Hygraph)
# HYGRAPH_MANAGEMENT_TOKEN=your_hygraph_management_token_here

# Use Hygraph as source (default: false)
# HYGRAPH_AS_SOURCE=false
