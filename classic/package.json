{
  "name": "classic",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0",
    "build": "node scripts/build-with-memory.js",
    "build:multi": "node scripts/build-multi-product.js",
    "build:multi:sequential": "node scripts/build-multi-product.js --sequential",
    "build:gcxone": "node scripts/build-multi-product.js gcxone",
    "build:gcsurge": "node scripts/build-multi-product.js gcsurge",
    "build:pdf": "node scripts/build-with-memory.js && node scripts/generate-pdfs.js",
    "sanity:pull": "node scripts/fetch-sanity-content.js",
    "sanity:pull:strict": "node -e \"process.env.SANITY_FETCH_STRICT='true'; require('./scripts/fetch-sanity-content').run().catch((err)=>{console.error(err.message); process.exit(1);});\"",
    "sanity:pull:preview": "node -e \"process.env.SANITY_INCLUDE_DRAFTS='true'; require('./scripts/fetch-sanity-content').run().catch((err)=>{console.error(err.message); process.exit(1);});\"",
    "sanity:push": "node scripts/sync-local-to-sanity.js",
    "sanity:push:apply": "node scripts/sync-local-to-sanity.js --apply",
    "sanity:rollback:list": "node scripts/rollback-sanity-fetch.js --list",
    "sanity:rollback": "node scripts/rollback-sanity-fetch.js",
    "sanity:rollback:apply": "node scripts/rollback-sanity-fetch.js --apply",
    "sanity:landing:audit": "node scripts/audit-landing-page-sync.js",
    "sanity:landing:audit:strict": "node scripts/audit-landing-page-sync.js --strict",
    "sanity:landing:audit:strict:all-collisions": "node scripts/audit-landing-page-sync.js --strict --strict-collisions",
    "sanity:landing:seed": "node scripts/seed-landing-pages-to-sanity.js",
    "sanity:landing:seed:apply": "node scripts/seed-landing-pages-to-sanity.js --apply",
    "sanity:landing:migrate-routes": "node scripts/migrate-landing-routes-to-sanity.js",
    "sanity:landing:migrate-routes:apply": "node scripts/migrate-landing-routes-to-sanity.js --apply",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --host 0.0.0.0",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "lint:mdx": "eslint src --ext .mdx",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,mdx}\"",
    "index:algolia": "node scripts/index-documentation.js",
    "search:index": "node scripts/generate-search-index.js",
    "search:embeddings": "npx tsx scripts/generate-embeddings.ts",
    "search:full": "npm run search:index && npm run search:embeddings",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "pdf:generate": "node scripts/generate-pdfs.js"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.1",
    "@cloudinary/react": "^1.14.3",
    "@cloudinary/url-gen": "^1.22.0",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@google/generative-ai": "^0.24.1",
    "@mdx-js/react": "^3.0.0",
    "@portabletext/markdown": "^1.1.4",
    "@posthog/react": "^1.8.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sanity/block-tools": "^3.70.0",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/schema": "^5.13.0",
    "@supabase/supabase-js": "^2.45.0",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "html2pdf.js": "^0.10.2",
    "jsdom": "^28.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "mermaid": "^11.14.0",
    "posthog-docusaurus": "^2.0.5",
    "posthog-js": "^1.364.5",
    "prism-react-renderer": "^2.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.0",
    "unist-util-visit": "^5.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@types/html2pdf.js": "^0.10.0",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "puppeteer": "^24.39.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.2",
    "unified": "^11.0.5"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
