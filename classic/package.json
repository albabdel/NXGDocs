{
  "name": "classic",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0",
    "build": "node scripts/build-with-memory.js",
    "sanity:pull": "node scripts/fetch-sanity-content.js",
    "sanity:pull:strict": "node -e \"process.env.SANITY_FETCH_STRICT='true'; require('./scripts/fetch-sanity-content').run().catch((err)=>{console.error(err.message); process.exit(1);});\"",
    "sanity:pull:preview": "node -e \"process.env.SANITY_INCLUDE_DRAFTS='true'; require('./scripts/fetch-sanity-content').run().catch((err)=>{console.error(err.message); process.exit(1);});\"",
    "sanity:push": "node scripts/sync-local-to-sanity.js",
    "sanity:push:apply": "node scripts/sync-local-to-sanity.js --apply",
    "sanity:rollback:list": "node scripts/rollback-sanity-fetch.js --list",
    "sanity:rollback": "node scripts/rollback-sanity-fetch.js",
    "sanity:rollback:apply": "node scripts/rollback-sanity-fetch.js --apply",
    "sanity:landing:audit": "node scripts/audit-landing-page-sync.js",
    "sanity:landing:audit:strict": "node scripts/audit-landing-page-sync.js --strict",
    "sanity:landing:audit:strict:all-collisions": "node scripts/audit-landing-page-sync.js --strict --strict-collisions",
    "sanity:landing:seed": "node scripts/seed-landing-pages-to-sanity.js",
    "sanity:landing:seed:apply": "node scripts/seed-landing-pages-to-sanity.js --apply",
    "sanity:landing:migrate-routes": "node scripts/migrate-landing-routes-to-sanity.js",
    "sanity:landing:migrate-routes:apply": "node scripts/migrate-landing-routes-to-sanity.js --apply",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --host 0.0.0.0",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "index:algolia": "node scripts/index-documentation.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@cloudinary/react": "^1.14.3",
    "@cloudinary/url-gen": "^1.22.0",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.8.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@google/generative-ai": "^0.24.1",
    "@mdx-js/react": "^3.0.0",
    "@portabletext/markdown": "^1.1.4",
    "@sanity/block-tools": "^3.70.0",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/schema": "^5.13.0",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "algoliasearch": "^4.25.3",
    "clsx": "^2.0.0",
    "framer-motion": "^12.23.25",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.554.0",
    "marked": "^17.0.4",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-toastify": "^11.0.5",
    "remark-gfm": "^4.0.1",
    "search-insights": "^2.17.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.22",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
