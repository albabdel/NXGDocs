{
  "name": "nxgen-docs",
  "version": "1.0.0",
  "description": "> **10 Breakthroughs. One Platform. Twice the Output. Zero Extra Hires.**",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "cd classic && npm install",
    "build": "cd classic && npm run build",
    "build:fast": "cd classic && npm run build",
    "start": "cd classic && npm start",
    "serve": "cd classic && npm run serve",
    "dev": "npm run build:fast && npx wrangler pages dev classic/build --port 8080 --compatibility-date 2024-01-01 --binding SANITY_PROJECT_ID=fjjuacab --binding SANITY_DATASET=production",
    "dev:full": "npx wrangler pages dev classic/build --port 8080 --compatibility-date 2024-01-01",
    "sidebar:seed": "node scripts/seed-sidebar-config.js",
    "sidebar:reconcile": "node scripts/reconcile-sanity-sidebar.js",
    "sidebar:reconcile:apply": "node scripts/reconcile-sanity-sidebar.js --apply",
    "sidebar:generate": "node scripts/generate-sidebars-from-sanity.js",
    "sanity:fetch": "node classic/scripts/fetch-sanity-content.js",
    "test:zoho-auth": "node scripts/test-zoho-auth.js",
    "build:multi": "cd classic && npm run build:multi",
    "build:multi:sequential": "cd classic && npm run build:multi:sequential",
    "build:gcxone": "cd classic && npm run build:gcxone",
    "build:gcsurge": "cd classic && npm run build:gcsurge",
    "import:confluence:surge": "npx ts-node scripts/import-confluence-surge.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/yazanabutaa/nxgen-docs.git"
  },
