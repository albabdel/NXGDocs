  "dependencies": {
    "@posthog/react": "^1.8.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.364.4"
  },
  "devDependencies": {
    "@portabletext/markdown": "^1.1.4",
    "@portabletext/schema": "^2.1.1",
    "@portabletext/toolkit": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.17.0",
    "@sanity/image-url": "^2.0.3",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "form-data": "^4.0.5",
    "jsdom": "^28.1.0",
    "mammoth": "^1.12.0",
    "pg": "^8.20.0",
    "supabase": "^2.84.6",
    "typescript": "^5.9.3",
    "wrangler": "^2.21.3"
  }
